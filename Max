class Solution:
    def maxLength(self, arr):
        prefix_sum = 0
        max_len = 0
        seen = {}

        for i in range(len(arr)):
            prefix_sum += arr[i]

            if prefix_sum == 0:
                max_len = i + 1

            if prefix_sum in seen:
                max_len = max(max_len, i - seen[prefix_sum])
            else:
                seen[prefix_sum] = i

        return max_len
